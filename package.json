{
  "name": "bms-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "External, typed end-to-end API tests for BSMS. Consumes the OpenAPI spec generated by the bsms repo via openapi-typescript + openapi-fetch.",
  "type": "module",
  "scripts": {
    "sync:spec": "node scripts/sync-spec.mjs",
    "gen:types": "openapi-typescript openapi/openapi.json -o src/api-types.ts",
    "setup": "npm run sync:spec && npm run gen:types",
    "pretest": "npm run gen:types",
    "test": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "dotenv": "^16.4.7",
    "openapi-typescript": "^7.5.0",
    "typescript": "^5"
  }
}
