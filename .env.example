# Copy to `.env`. The defaults below target a LOCAL bsms app + LOCAL Supabase and
# are non-secret (the Supabase key only works on a local stack), so they work as-is
# for local runs. Override for staging.

# The running bsms app under test (start it from the bsms repo against local Supabase).
APP_BASE_URL=http://127.0.0.1:3000

# Local Supabase (used to mint auth tokens for protected-endpoint tests).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Seeded staff login (matches bsms supabase/seed.sql). E2E_ADMIN_EMAIL is a username.
E2E_ADMIN_EMAIL=admin
E2E_ADMIN_PASSWORD=Password123!

# Safety: the suite refuses non-local APP_BASE_URL / SUPABASE_URL unless this is 1.
# NEVER point these at production.
# E2E_ALLOW_REMOTE=1

# Optional: path to the bsms-generated spec for `npm run sync:spec`
# (default: ../bsms/openapi/openapi.json)
# BSMS_SPEC_PATH=../bsms/openapi/openapi.json
